PORT=5000
MONGO_URI=mongodb://localhost:27017/internalCredentialManager
JWT_SECRET=change_this_to_a_long_random_string
CREDENTIAL_SECRET=change_this_to_a_32_character_string

# Set to production on your live server so cookies use secure:true (HTTPS only)
NODE_ENV=development

# Comma-separated list of extra allowed origins for CORS in production
# e.g. ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=

# Browser push notifications (Web Push / VAPID).
# Generate with: npx web-push generate-vapid-keys
# Paste the "Public Key" and "Private Key" it prints below. Without these,
# push notifications are silently disabled but the rest of the app works fine.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
